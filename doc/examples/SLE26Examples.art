(* 5. XCount example - small step reduction rules *)
(*
!traceLevel 4
X ::= 'x' | 'x' X

-X1  --- X(x) -> 1

-X2
_n |> __int32(_)
--- 
X(x, _n) -> __add(_n, 1)

-X2R
_E -> _EP
--- 
X(x, _E) -> X(x, _EP)

!try "xxx"
*)

(*****************************************************************************)

(* 6. XCount example - big step reduction rules *)
(*
!traceLevel 4
X ::= 'x' | 'x' X

-X1  --- X(x) -> 1

-X2
_E -> _EP
--- 
X(x, _E) -> __add(_EP, 1)

!try "xxx"
*)

