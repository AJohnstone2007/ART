(* 4 March 2026 - bounded string examples for the SLE26  *)

(* Uncomment exactly one example and run as java -jar art.jar boundedStringExamples.art *)

(*****************************************************************************)

(* 1. Bounded string example - Attribute-Action with Java actions *)
(*
!interpreter attributeAction

S <v::boolean> ::= I !! T1.b = I1.n; !! T !! S.v = T1.v; !! !! System.out.println("S.v = " + S.v); !!
       
T <v::boolean b::int> ::= X !! T.v = X1.c <= T.b; !!

X <c::int> ::= 'x' X !! X.c = X1.c+1; !! | 'x' !! X.c = 1; !!

I <n::int> ::= '1' !! I.n = 1; !! | '2' !! I.n = 2; !!  | '3' !! I.n = 3; !! 

!generate actions 

!try "3 xxx"
!show 'sle3xxx.dot' full indexed derivationTerm
!try "2 xxxx"
!show 'sle2xxxx.dot' full indexed derivationTerm
*)

(*****************************************************************************)

(* 2. Bounded string example - Attribute Grammar with Value equations *)
(*
(* Not yet runnable as Value equations are not being interpreted but can be used to provide typeset text for paper*)

!interpreter attributeAction

S ::= I T1.b = I1.n T S.v = T1.v
       
T ::= X T.v = __le(X1.c, T.b)

X ::= 'x' X X.c=__add(X1.c, 1) | 'x' X.c = 1 

I ::= '1' I.n=1 | '2' I.n=2 | '3' I.n=3

!generate actions 
!try "3 xxx"
*)

