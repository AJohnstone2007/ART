(* 9. Bounded string - modelling attribute evaluation by arity-extending nonterminals: big step evaluation *)
(*

!traceLevel 4

S ::= __int32  T    // Start rule collects integer bound and passes to T
T ::= X             // Test rule receives bound from S and evaluates X subtree, then compares
X ::= 'x' | 'x' X   // X rule counts Xs as in example 1

__int32 ::= '1' | '2' | '3' // This generates terms of the form __int32(3) which is ART's way of describing a typed number

(* Phase 1 - extend derivation nodes with attribute arguments in one step *)

-SA
_E -> _EP
--- S(_b, _E) -> SP(_b, _EP, __empty)  // add attribute S.v

-TA
_E -> _EP
--- T(_E) -> TP(_EP, __empty, __empty)  // add attributes T.b and T.v

-XA1
--- X(x) -> XP(x, __empty)  // add attribute X.c

-XA2
_E -> _EP
---
X(x, _E) -> XP(x, _EP, __empty) // add attribute X.c

(* Phase 2 - evaluate the attributes in one step *)
-SE
TP(_E, _n, __empty) -> TP(_EP, _n, _v) 
---
SP(_n, TP( _E, __empty, __empty), __empty) -> SP(_n, TP( _EP, _n, _v), _v) 

-TE1
XP(x, __empty) -> XP(x, _c) 
---
TP(XP(x, __empty), _b, __empty) -> TP(XP(x, _c), _b, __le(_c, _b))

-TE2
XP(x,  _E, __empty) -> XP(x,  _EP, _c) 
---
TP(XP(x,  _E, __empty), _b, __empty) -> TP(XP(x,  _EP, _c), _b, __le(_c, _b))

-XE1 // No need for recursion as we are at leaf level
---
XP(x, __empty) -> XP(x, 1)  

-XE2A
 _E -> _EP _EP |> XP(x, _c)
---
XP(x,  _E, __empty) -> XP(x, XP(x, _c), __add(_c, 1))  

-XE2B
 _E -> _EP _EP |> XP(x,  _EP, _c)
---
XP(x,  _E, __empty) -> XP(x, XP(x,  _EP, _c), __add(_c, 1))  


(* Phase 3 - once the top level attribute is a boolean, rewrite to that final boolean  value *)

-Z --- SP(_, _, _v) -> _v

!try "3 xxx"
*)

(*****************************************************************************)

(* 10. Bounded string - modelling attribute evaluation by tupling: big step evaluation *)
(*
!traceLevel 4

S ::= __int32  T    // Start rule collects integer bound and passes to T
T ::= X             // Test rule receives bound from S and evaluates X subtree, then compares
X ::= 'x' | 'x' X   // X rule counts Xs as in example 1

__int32 ::= '1' | '2' | '3' // This generates terms of the form __int32(3) which is ART's way of describing a typed number

(* Phase 1 - extend derivation nodes with attribute arguments in one step *)

-SA
_E -> _EP
--- S(_b, _E) -> < SP(_b, _EP), __empty >  // add attribute S.v

-TA
_E -> _EP
--- T(_E) -> < TP(_EP), __empty, __empty>  // add attributes T.b and T.v

-XA1
--- X(x) -> < XP(x), __empty>  // add attribute X.c

-XA2
_E -> _EP
---
X(x, _E) -> < XP(x, _EP) __empty> // add attribute X.c

(* Phase 2 - evaluate the attributes in one step *)
-SE
< TP(_E), _n, __empty> -> < TP(_EP), _n, _v> 
---
<SP(_n, <TP(_E), __empty, __empty>), __empty> -> <SP(_n, <TP(_EP), _n, _v>), _v> 

-TE1
<XP(x), __empty> -> <XP(x), _c> 
---
<TP(<XP(x), __empty>), _b, __empty> -> <TP(<XP(x), _c>), _b, __le(_c, _b)>

-TE2
<XP(x,  _E), __empty> -> <XP(x,  _EP), _c> 
---
<TP(<XP(x,  _E), __empty>), _b, __empty> -> <TP(<XP(x,  _EP), _c>), _b, __le(_c, _b)>

-XE1 // No need for recursion as we are at leaf level
---
<XP(x), __empty> -> <XP(x), 1>  

-XE2A
_E -> _EP _EP |> <XP(x), _c>
---
<XP(x,  _E), __empty> -> <XP(x, <XP(x), _c>), __add(_c, 1)>  

-XE2B
 _E -> _EP _EP |> <XP(x,  _EP), _c>
---
<XP(x,  _E), __empty> -> <XP(x, <XP(x,  _EP), _c>), __add(_c, 1)>  


(* Phase 3 - once the top level attribute is a boolean, rewrite to that final boolean  value *)

-Z --- < SP(_, _), _v> -> _v

//!try "3 x"
!try "3 xxx"
//!try "3 xxxx"
*)

(*****************************************************************************)

(* 11. Bounded string - modelling attribute evaluation eSOS style: big step evaluation *)
(*
!traceLevel 4

S ::= __int32  T    // Start rule collects integer bound and passes to T
T ::= X             // Test rule receives bound from S and evaluates X subtree, then compares
X ::= 'x' | 'x' X   // X rule counts Xs as in example 1

__int32 ::= '1' | '2' | '3' // This generates terms of the form __int32(3) which is ART's way of describing a typed number

!configuration -> _tau::__map

-S
__get(_tau, xc) |> __empty   _E, __put(_tau, tb, _n) -> _EP, _tauP
---
S(_n, _E), _tau -> S(_n, _E), __put(_tauP, sv, __get(_tauP, tv))

-T
_E, _tau -> _EP, _tauP
---
T(_E), _tau -> T(_EP), __put(_tauP, tv, __le(__get(_tauP, xc), __get(_tauP, tb)))

-X1
---
X(x), _tau -> X(x), __put(_tau, xc, 1) 

-X2
_E, _tau -> _EP, _tauP
---
X(x, _E), _tau -> X(x, _EP), __put(_tauP, xc, __add(__get(_tauP, xc), 1))

-Z
__get(_tau, sv) |> _sv   _sv |> __bool(_)
--- S(_, _), _tau -> _sv

//!try "3 x"
!try "3 xxx"
//!try "3 xxxx"
*)

(*****************************************************************************)

(* 12. GCD - small step SOS *)
(*
!traceLevel 4

!configuration -> _sig::__map

-assign  _n |> __int32(_)      --- assign(_X,_n),_sig -> __done,__put(_sig,_X,_n)
-assignR _E,_sig -> _I,_sigP --- assign(_X,_E),_sig -> assign(_X,_I),_sigP

-deref --- deref(_R),_sig -> __get(_sig,_R),_sig

-sequenceDone                      --- seq(__done, _C),_sig -> _C,_sig
-sequence _C1,_sig -> _C1P,_sigP --- seq(_C1,_C2),_sig -> seq(_C1P,_C2),_sigP

-ifTrue                          --- if(true,_C1,_C2),_sig -> _C1,_sig
-ifFalse                         --- if(false,_C1,_C2),_sig -> _C2,_sig
-ifResolve _E,_sig ->_EP,_sigP --- if(_E,_C1,_C2),_sig -> if(_EP,_C1,_C2),_sigP

-while --- while(_E,_C),_sig -> if(_E,seq(_C,while(_E,_C)),__done),_sig

-gt  _n1 |> __int32(_)  _n2 |> __int32(_)     --- gt(_n1,_n2),_sig  ->  __gt(_n1,_n2),_sig 
-gtR _n |> __int32(_)  _E2,_sig -> _I2,_sigP --- gt(_n,_E2),_sig   -> gt(_n,_I2),_sigP
-gtL _E1,_sig -> _I1,_sigP                  --- gt(_E1,_E2),_sig  -> gt(_I1,_E2),_sigP

-ne  _n1 |> __int32(_) _n2 |> __int32(_)      --- ne(_n1,_n2),_sig  -> __ne(_n1,_n2),_sig
-neR _n |> __int32(_)  _E2,_sig -> _I2,_sigP --- ne(_n,_E2) ,_sig  -> ne(_n,_I2),_sigP
-neL _E1,_sig -> _I1,_sigP                  --- ne(_E1,_E2),_sig  -> ne(_I1,_E2),_sigP

-sub  _n1 |> __int32(_) _n2 |> __int32(_)     --- sub(_n1,_n2),_sig -> __sub(_n1,_n2),_sig
-subR _n |> __int32(_) _E2,_sig -> _I2,_sigP --- sub(_n,_E2),_sig  -> sub(_n,_I2),_sigP
-subL _E1,_sig -> _I1,_sigP                  --- sub(_E1,_E2),_sig -> sub(_I1,_E2),_sigP

seq ::= statement^^ | statement seq 
statement ::= assign^^ | while^^ | if^^
assign ::= &ID ':='^ expression ';'^
while ::= 'while'^ expression 'do'^ statement
if ::= 'if'^ expression 'then'^ statement | 'if'^ expression 'then'^ statement 'else'^ statement
expression ::= pred^^
pred ::= addOps^^ | gt^^ | ne^^
  gt ::= addOps '>'^ addOps
  ne ::= addOps '!='^ addOps 
addOps  ::= operand^^ | sub^^
  sub ::= addOps '-'^ operand
operand ::= __int32^^ | deref^^
__int32 ::= &INTEGER
deref ::= &ID

!print "Try with internal syntax term"
!try seq(assign(a,6), seq(assign(b,9), while(ne(deref(a), deref(b)), if(gt(deref(a), deref(b)), assign(a, sub(deref(a), deref(b))), assign(b, sub(deref(b), deref(a))))))), __map
!print "Try with external syntax"
!try "a := 6; b := 9; while a != b do if a > b then a := a - b; else b := b - a; gcd := a;"

!show 'RDT.dot' full indexed derivationTerm

---
statement(assign(_I, EQ, _E)) ~> assign(_I, _E)
*)
(*****************************************************************************)

(* 13. GCD - Attribute-Action specification *)
(*
!traceLevel 4

!interpreter attributeAction

!support
!! import java.util.Map; import java.util.HashMap; !!
!! Map<String, Integer> variables = new HashMap<>(); !!

statements ::= statement statements
| statement !! System.out.println("Final variable map " + variables); !! 

statement ::= 
  id ':=' pred ';' !! variables.put(id1.v, pred1.v); !!     // assignment 
| 'if' pred 'then' statement!< 'else' statement!<           // if statement 
  !! if (pred1.v != 0) interpret(statement1); else interpret(statement2); !! 
| 'while' pred!< 'do' statement!<                           // while statement 
  !! interpret(pred1); while (pred1.v != 0) { interpret(statement1); interpret(pred1); } !! 

pred ::= addOps !! pred.v = addOps1.v; !!
| addOps '>'  addOps !! pred.v = addOps1.v >  addOps2.v ? 1 : 0; !! // Greater than 
| addOps '!=' addOps !! pred.v = addOps1.v != addOps2.v ? 1 : 0; !! // Not equal to 

addOps ::= operand !! addOps.v = operand1.v; !!  
| addOps '-' operand !! addOps.v = addOps1.v - operand1.v; !!               // Subtract 

operand ::=int32 !!operand.v = int321.v; !!                           // Integer literal 
| id !! operand.v = variables.get(id1.v); !!                     // Variable access 
| '(' addOps ')' !! operand.v = addOps1.v; !!                        // Parenthesised expression 
       
// Lexical rules
id <v::String> ::= &ID !! id.v = lexeme(); !!  
int32          ::= &INTEGER   !! int32.v = Integer.parseInt(lexeme()); !!

!generate actions 
!try "a := 6; b := 9; while a != b do if a > b then a := a - b; else b := b - a; gcd := a;"
*)

