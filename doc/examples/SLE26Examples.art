(* 7. Bounded string example - small step reduction rules *)
(*
!traceLevel 3
S ::= __int32  T    // Start rule collects integer bound and passes to T
T ::= X             // Test rule receives bound from S and evaluates X subtree, then compares
X ::= 'x' | 'x' X   // X rule counts Xs as in example 1

__int32 ::= '1' | '2' | '3' // This generates terms of the form __int32(3) which is ART's way of describing a typed number
  
-S
--- S(_n, T( _E)) -> T(_n,  _E)
 
-T
_m |> __int32(_)
---
T(_n, _m) -> __le(_m ,_n)

-TR
 _E ->  _EP
---
T(_n,  _E) -> T(_n,  _EP)
 
-X1  --- X(x) -> 1

-X2
_n |> __int32(_)
--- 
X(x, _n) -> __add(_n, 1)

-X2R
_E -> _EP
--- 
X(x, _E) -> X(x, _EP)

//!try "3 x"
//!try "3 xx"
!try "3 xxx"
//!try "3 xxxx"
//!try "3 xxxxx"
//!try "3 xxxxxx"
//!try "3 xxxxxxx"
//!try "3 xxxxxxxx"
//!try "3 xxxxxxxxx"
//!try "3 xxxxxxxxxx"
*)

(*****************************************************************************)
(* 8. Bounded string example - big step reduction rules *)
(*
!traceLevel 2

S ::= __int32  T    // Start rule collects integer bound and passes to T
T ::= X             // Test rule receives bound from S and evaluates X subtree, then compares
X ::= 'x' | 'x' X   // X rule counts Xs as in example 1

__int32 ::= '1' | '2' | '3' // This generates terms of the form __int32(3) which is ART's way of describing a typed number
 
-top
T(_n,  _E) -> _TP
--- 
S(_n, T( _E)) -> _TP 
 
-tst 
 _E ->  _EP 
---
T(_n,  _E) -> __le( _EP ,_n)

-X1  --- X(x) -> 1

-X2
_E -> _EP
--- 
X(x, _E) -> __add(_EP, 1) 

//!try "3 x"
//!try "3 xx"
!try "3 xxx"
//!try "3 xxxx"
//!try "3 xxxxx"
//!try "3 xxxxxx"
//!try "3 xxxxxxx"
//!try "3 xxxxxxxx"
//!try "3 xxxxxxxxx"
//!try "3 xxxxxxxxxx"
*)

