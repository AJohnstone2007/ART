(*****************************************************************************)

(* 5. XCount example - small step reduction rules *)

(*
(* Only used to generate tree figures *)
!traceLevel 3
X ::= 'x' | 'x' X

-X1  --- X(x) -> 1

-X2
_n |> __int32(_)
--- 
X(x, _n) -> __add(_n, 1)

-X2R
_E -> _EP
--- 
X(x, _E) -> X(x, _EP)

!try "xxx"
*)

(*****************************************************************************)

(* 6. XCount example - big step reduction rules *)

(*
(* Not used in paper *)

X ::= 'x' | 'x' X

-X1  --- X(x) -> 1

-X2
_E -> _EP
--- 
X(x, _E) -> __add(_EP, 1)

!try "xxx"
*)

(*****************************************************************************)

(* 7. Bounded string example - small step reduction rules *)

(*
!traceLevel 3
S ::= __int32  T    // Start rule collects integer bound and passes to T
T ::= X             // Test rule receives bound from S and evaluates X subtree, then compares
X ::= 'x' | 'x' X   // X rule counts Xs as in example 1

__int32 ::= '1' | '2' | '3' // This generates terms of the form __int32(3) which is ART's way of describing a typed number
  
-top 
--- S(_n, T( _E)) -> T(_n,  _E)
 
-tst
_m |> __int32(_)
---
T(_n, _m) -> __le(_m ,_n)

-tstR
 _E ->  _EP
---
T(_n,  _E) -> T(_n,  _EP)
 
-X1  --- X(x) -> 1

-X2
_n |> __int32(_)
--- 
X(x, _n) -> __add(_n, 1)

-X2R
_E -> _EP
--- 
X(x, _E) -> X(x, _EP)

!try "3 xxx"
*)

(*****************************************************************************)

(* 8. Bounded string example - big step reduction rules *)
(*
S ::= __int32  T    // Start rule collects integer bound and passes to T
T ::= X             // Test rule receives bound from S and evaluates X subtree, then compares
X ::= 'x' | 'x' X   // X rule counts Xs as in example 1

__int32 ::= '1' | '2' | '3' // This generates terms of the form __int32(3) which is ART's way of describing a typed number
 
-top
T(_n,  _E) -> _TP
--- 
S(_n, T( _E)) -> _TP 
 
-tst 
 _E ->  _EP 
---
T(_n,  _E) -> __le( _EP ,_n)

-X1  --- X(x) -> 1

-X2
_E -> _EP
--- 
X(x, _E) -> __add(_EP, 1) 

!try "3 xxx"
*)

(*****************************************************************************)

(* 9. Bounded string example - modelling attribute evaluation by extending nonterminals: small step evaluation *)
(*
(* Not working ! *)
!traceLevel 10

S ::= __int32  T    // Start rule collects integer bound and passes to T
T ::= X             // Test rule receives bound from S and evaluates X subtree, then compares
X ::= 'x' | 'x' X   // X rule counts Xs as in example 1

__int32 ::= '1' | '2' | '3' // This generates terms of the form __int32(3) which is ART's way of describing a typed number

(* Phase 1 - extend derivation nodes with attribute arguments in one step *)

-SA
_E -> _EP
--- S(_b, _E) -> SP(_b, _EP, __empty)  // add attribute S.v

-TA
_E -> _EP
--- T(_E) -> TP(_EP, __empty, __empty)  // add attributes T.b and T.v

-XA1
--- X(x) -> XP(x, __empty)  // add attribute X.c

-XA2
_E -> _EP
---
X(x, _E) -> XP(x, _EP, __empty) // add attribute X.c

(* Phase 2 - evaluate the attributes in multiple steps *)
---
SP(_b, TP(_E, __empty, __empty), __empty) -> TP(_E, _b, __empty)

-XE1  --- XP(x, __empty) -> XP(x, 1)

-XE2
_n |> __int32(_)
--- 
X(x, _n) -> X(x, __add(_n, 1))

-X2R
_E -> _EP
--- 
X(x, _E) -> X(x, _EP)

(* Phase 3 - once the top level attribute is a boolean, rewrite to that final boolean  value *)

-P3 --- SP(_, _, _v) -> _v

!try "3 x"
!try "3 xxx"
!try "3 xxxx"
*)

(*****************************************************************************)

(* 10. Bounded string - modelling attribute evaluation by extending nonterminals: big step evaluation *)
(*
!traceLevel 3

S ::= __int32  T    // Start rule collects integer bound and passes to T
T ::= X             // Test rule receives bound from S and evaluates X subtree, then compares
X ::= 'x' | 'x' X   // X rule counts Xs as in example 1

__int32 ::= '1' | '2' | '3' // This generates terms of the form __int32(3) which is ART's way of describing a typed number

(* Phase 1 - extend derivation nodes with attribute arguments in one step *)

-SA
_E -> _EP
--- S(_b, _E) -> SP(_b, _EP, __empty)  // add attribute S.v

-TA
_E -> _EP
--- T(_E) -> TP(_EP, __empty, __empty)  // add attributes T.b and T.v

-XA1
--- X(x) -> XP(x, __empty)  // add attribute X.c

-XA2
_E -> _EP
---
X(x, _E) -> XP(x, _EP, __empty) // add attribute X.c

(* Phase 2 - evaluate the attributes in one step *)
-SE
TP(_E, _n, __empty) -> TP(_EP, _n, _v) 
---
SP(_n, TP( _E, __empty, __empty), __empty) -> SP(_n, TP( _EP, _n, _v), _v) 

-TE1
XP(x, __empty) -> XP(x, _c) 
---
TP(XP(x, __empty), _b, __empty) -> TP(XP(x, _c), _b, __le(_c, _b))

-TE2
XP(x,  _E, __empty) -> XP(x,  _EP, _c) 
---
TP(XP(x,  _E, __empty), _b, __empty) -> TP(XP(x,  _EP, _c), _b, __le(_c, _b))

-XE1 // No need for recursion as we are at leaf level
---
XP(x, __empty) -> XP(x, 1)  

-XE2A
 _E -> _EP _EP |> XP(x, _c)
---
XP(x,  _E, __empty) -> XP(x, XP(x, _c), __add(_c, 1))  

-XE2B
 _E -> _EP _EP |> XP(x,  _EP, _c)
---
XP(x,  _E, __empty) -> XP(x, XP(x,  _EP, _c), __add(_c, 1))  


(* Phase 3 - once the top level attribute is a boolean, rewrite to that final boolean  value *)

-P3 --- SP(_, _, _v) -> _v

!try "3 x"
!try "3 xxx"
!try "3 xxxx"
*)

(*****************************************************************************)

(* 11. Bounded string - modelling attribute evaluation by tupling: big step evaluation *)

!traceLevel 3

S ::= __int32  T    // Start rule collects integer bound and passes to T
T ::= X             // Test rule receives bound from S and evaluates X subtree, then compares
X ::= 'x' | 'x' X   // X rule counts Xs as in example 1

__int32 ::= '1' | '2' | '3' // This generates terms of the form __int32(3) which is ART's way of describing a typed number

(* Phase 1 - extend derivation nodes with attribute arguments in one step *)

-SA
_E -> _EP
--- S(_b, _E) -> < SP(_b, _EP), __empty >  // add attribute S.v

-TA
_E -> _EP
--- T(_E) -> < TP(_EP), __empty, __empty>  // add attributes T.b and T.v

-XA1
--- X(x) -> < XP(x), __empty>  // add attribute X.c

-XA2
_E -> _EP
---
X(x, _E) -> < XP(x, _EP) __empty> // add attribute X.c

(* Phase 2 - evaluate the attributes in one step *)
-SE
< TP(_E), _n, __empty> -> < TP(_EP), _n, _v> 
---
<SP(_n, <TP(_E), __empty, __empty>), __empty> -> <SP(_n, <TP(_EP), _n, _v>), _v> 

-TE1
<XP(x), __empty> -> <XP(x), _c> 
---
<TP(<XP(x), __empty>), _b, __empty> -> <TP(<XP(x), _c>), _b, __le(_c, _b)>

-TE2
<XP(x,  _E), __empty> -> <XP(x,  _EP), _c> 
---
<TP(<XP(x,  _E), __empty>), _b, __empty> -> <TP(<XP(x,  _EP), _c>), _b, __le(_c, _b)>

-XE1 // No need for recursion as we are at leaf level
---
<XP(x), __empty> -> <XP(x), 1>  

-XE2A
_E -> _EP _EP |> <XP(x), _c>
---
<XP(x,  _E), __empty> -> <XP(x, <XP(x), _c>), __add(_c, 1)>  

-XE2B
 _E -> _EP _EP |> <XP(x,  _EP), _c>
---
<XP(x,  _E), __empty> -> <XP(x, <XP(x,  _EP), _c>), __add(_c, 1)>  


(* Phase 3 - once the top level attribute is a boolean, rewrite to that final boolean  value *)

-P3 --- < SP(_, _), _v> -> _v

!try "3 x"
!try "3 xxx"
!try "3 xxxx"


(*****************************************************************************)

(* Output LaTeX rules for the paper *)

!print 'artScript.tex' latex scriptTerm

//!print raw scriptTerm
